---
---
<section id="horarios" class="relative py-24 bg-smoke-900 border-t border-smoke-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16">
            <h2 class="gsap-reveal text-sm text-orange-400 tracking-widest uppercase font-semibold mb-2">Agenda</h2>
            <h3 class="gsap-reveal text-3xl md:text-4xl font-serif text-white">Horario de Actividades</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Tarjeta 1 -->
            <div class="gsap-card bg-smoke-800 p-8 rounded-2xl border border-smoke-700 hover:border-gold/50 transition-colors group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full -z-10 group-hover:bg-gold/10 transition-colors"></div>
                <div class="w-12 h-12 rounded-full bg-smoke-700 flex items-center justify-center text-gold mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-sun text-xl"></i>
                </div>
                <h4 class="text-xl text-white font-semibold mb-2">Culto Dominical</h4>
                <p class="text-gray-400 text-sm mb-4">Servicio principal de alabanza, adoración y mensaje de la Palabra.</p>
                <div class="flex items-center text-orange-400 font-medium">
                    <i class="fa-regular fa-clock mr-2"></i> Domingos, 10Hrs
                </div>
            </div>
            
            <!-- Tarjeta 2 -->
            <div class="gsap-card bg-smoke-800 p-8 rounded-2xl border border-smoke-700 hover:border-gold/50 transition-colors group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full -z-10 group-hover:bg-gold/10 transition-colors"></div>
                <div class="w-12 h-12 rounded-full bg-smoke-700 flex items-center justify-center text-gold mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-users text-xl"></i>
                </div>
                <h4 class="text-xl text-white font-semibold mb-2">Servicio de Oración</h4>
                <p class="text-gray-400 text-sm mb-4">Un espacio dedicado a la Oración y la lectura de la palabra.</p>
                <div class="flex items-center text-orange-400 font-medium">
                    <i class="fa-regular fa-clock mr-2"></i> Martes, 17Hrs
                </div>
            </div>

            <!-- Tarjeta 3 -->
            <div class="gsap-card bg-smoke-800 p-8 rounded-2xl border border-smoke-700 hover:border-gold/50 transition-colors group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full -z-10 group-hover:bg-gold/10 transition-colors"></div>
                <div class="w-12 h-12 rounded-full bg-smoke-700 flex items-center justify-center text-gold mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-book-bible"></i>
                </div>
                <h4 class="text-xl text-white font-semibold mb-2">Escuela Bíblica</h4>
                <p class="text-gray-400 text-sm mb-4">Un espacio dedicado al estudio de la palabra de Dios.</p>
                <div class="flex items-center text-orange-400 font-medium">
                    <i class="fa-regular fa-clock mr-2"></i> Miercoles 16Hrs
                </div>
            </div>

            <!-- Tarjeta 4 -->
            <div class="gsap-card bg-smoke-800 p-8 rounded-2xl border border-smoke-700 hover:border-gold/50 transition-colors group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full -z-10 group-hover:bg-gold/10 transition-colors"></div>
                <div class="w-12 h-12 rounded-full bg-smoke-700 flex items-center justify-center text-gold mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-seedling"></i>
                </div>
                <h4 class="text-xl text-white font-semibold mb-2">Reunión de Jóvenes</h4>
                <p class="text-gray-400 text-sm mb-4">Profundizamos en las escrituras para crecer espiritualmente como Jóvenes.</p>
                <div class="flex items-center text-orange-400 font-medium">
                    <i class="fa-regular fa-clock mr-2"></i> Viernes, 17Hrs
                </div>
            </div>

            <!-- Tarjeta 5 -->
            <div class="gsap-card bg-smoke-800 p-8 rounded-2xl border border-smoke-700 hover:border-gold/50 transition-colors group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full -z-10 group-hover:bg-gold/10 transition-colors"></div>
                <div class="w-12 h-12 rounded-full bg-smoke-700 flex items-center justify-center text-gold mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-music text-xl"></i>
                </div>
                <h4 class="text-xl text-white font-semibold mb-2">Ensayo Ministerio ECOS</h4>
                <p class="text-gray-400 text-sm mb-4">Reunión de ensayos del ministerio de Adoración ECOS</p>
                <div class="flex items-center text-orange-400 font-medium">
                    <i class="fa-regular fa-clock mr-2"></i> Sábado, 09Hrs
                </div>
            </div>

            <!-- Tarjeta 6 -->
            <div class="gsap-card bg-smoke-800 p-8 rounded-2xl border border-smoke-700 hover:border-gold/50 transition-colors group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gold/5 rounded-bl-full -z-10 group-hover:bg-gold/10 transition-colors"></div>
                <div class="w-12 h-12 rounded-full bg-smoke-700 flex items-center justify-center text-gold mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-people-robbery"></i>
                </div>
                <h4 class="text-xl text-white font-semibold mb-2">Ensayo Ministerio de Danza</h4>
                <p class="text-gray-400 text-sm mb-4">Reunión de ensayos del ministerio de Danza de nuestra casa</p>
                <div class="flex items-center text-orange-400 font-medium">
                    <i class="fa-regular fa-clock mr-2"></i> Sábado, 16Hrs
                </div>
            </div>
        </div>
    </div>
</section>