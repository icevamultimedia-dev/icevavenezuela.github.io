<style>
    .logo-animado { animation: levitar 4s ease-in-out infinite; will-change: transform, filter; }
    @keyframes levitar {
        0% { transform: translateY(0px) scale(1); filter: drop-shadow(0 0 0 rgba(96, 165, 250, 0)); }
        50% { transform: translateY(-6px) scale(1.02); filter: drop-shadow(0 8px 15px rgba(96, 165, 250, 0.4)); }
        100% { transform: translateY(0px) scale(1); filter: drop-shadow(0 0 0 rgba(96, 165, 250, 0)); }
    }
    .animate-marquee { animation: marquee 30s linear infinite; }
    .hover\:pause-animation:hover .animate-marquee { animation-play-state: paused; }
    @keyframes marquee { 0% { transform: translateX(0%); } 100% { transform: translateX(-50%); } }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // --- LÓGICA DE LA CUENTA REGRESIVA BIKURIM ---
        const targetDate = new Date("Apr 19, 2026 10:00:00").getTime();

        const updateCountdown = () => {
            const now = new Date().getTime();
            const distance = targetDate - now;

            if (distance < 0) {
                document.querySelectorAll('.countdown-timer').forEach(el => {
                    (el as HTMLElement).innerText = "¡LA FIESTA HA COMENZADO!";
                });
                return;
            }

            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            const fDays = String(days).padStart(2, '0');
            const fHours = String(hours).padStart(2, '0');
            const fMins = String(minutes).padStart(2, '0');
            const fSecs = String(seconds).padStart(2, '0');

            const timeString = `${fDays}D ${fHours}H ${fMins}M ${fSecs}S`;
            
            document.querySelectorAll('.countdown-timer').forEach(el => {
                (el as HTMLElement).innerText = timeString;
            });
        };

        setInterval(updateCountdown, 1000);
        updateCountdown();

        // --- 🌟 LÓGICA DEL MENÚ MÓVIL 🌟 ---
        const toggleBtn = document.getElementById('mobile-menu-toggle');
        const closeBtn = document.getElementById('mobile-menu-close');
        const overlay = document.getElementById('mobile-nav-overlay');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        const openMobileMenu = () => {
            if(overlay) {
                overlay.classList.remove('opacity-0', 'invisible');
                overlay.classList.add('opacity-100', 'visible');
                // Bloquear el scroll del fondo cuando el menú está abierto
                document.body.style.overflow = 'hidden'; 
            }
        };

        const closeMobileMenu = () => {
            if(overlay) {
                overlay.classList.add('opacity-0', 'invisible');
                overlay.classList.remove('opacity-100', 'visible');
                // Restaurar el scroll del fondo
                document.body.style.overflow = '';
            }
        };

        if(toggleBtn) toggleBtn.addEventListener('click', openMobileMenu);
        if(closeBtn) closeBtn.addEventListener('click', closeMobileMenu);
        
        // Cerrar el menú al hacer clic en cualquier enlace
        mobileLinks.forEach(link => {
            link.addEventListener('click', closeMobileMenu);
        });
    });
</script>