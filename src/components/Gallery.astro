---
---
<section id="galeria" class="py-24 relative bg-smoke-900 overflow-hidden">
    <!-- Destello central azul -->
    <div class="flare-bg w-[400px] h-[400px] top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 opacity-20"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16">
            <h2 class="gsap-reveal text-sm text-blue-400 tracking-widest uppercase font-semibold mb-2 font-sans">Comunidad</h2>
            <h3 class="gsap-reveal text-4xl md:text-5xl font-serif text-white">Nuestras Actividades</h3>
        </div>

        <!-- PORTADA DE GALERÍA PRINCIPAL -->
        <a href="https://drive.google.com/drive/folders/181eUiH0BeQjpE2yFWkcNpf-dwBvQ1Fdk?usp=sharing" target="_blank" rel="noopener noreferrer" class="gsap-gallery block relative w-full h-[350px] md:h-[450px] rounded-2xl overflow-hidden mb-8 group cursor-pointer border border-smoke-700 hover:border-gold/50 transition-colors shadow-2xl">
            <!-- 🌟 OPTIMIZACIÓN: Carga perezosa y decodificación asíncrona 🌟 -->
            <img src="/14.webp" loading="lazy" decoding="async" alt="Álbum completo en Google Drive" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            
            <!-- Gradiente para legibilidad -->
            <div class="absolute inset-0 bg-gradient-to-t from-smoke-900 via-smoke-900/40 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <!-- Contenido del Enlace -->
            <div class="absolute bottom-0 left-0 p-6 md:p-10 flex flex-col md:flex-row md:items-end justify-between w-full gap-4">
                <div>
                    <h4 class="text-3xl md:text-4xl font-bold text-white mb-2">Aniversario N36/2025</h4>
                    <p class="text-blue-400 font-sans flex items-center gap-2 text-sm md:text-base">
                        <i class="fa-brands fa-google-drive"></i> Explora todas nuestras fotografias y búscate
                    </p>
                </div>
                <!-- Botón de acción flotante -->
                <div class="flex-shrink-0 w-14 h-14 rounded-full bg-smoke-800 border border-smoke-700 flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-smoke-900 group-hover:scale-110 transition-all duration-300">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i>
                </div>
            </div>
        </a>

        <!-- Mosaico Secundario (Convertidos en Enlaces <a>) -->
        <div class="masonry-grid">
            <!-- Item 1: Primicias 2025 -->
            <a href="https://drive.google.com/drive/folders/12vdmEoMteJuLB942sYiiqGi1wcyODPBM?usp=sharing" target="_blank" rel="noopener noreferrer" class="masonry-item block gsap-gallery overflow-hidden rounded-xl relative group cursor-pointer">
                <!-- 🌟 OPTIMIZACIÓN APLICADA 🌟 -->
                <img src="/01.webp" loading="lazy" decoding="async" alt="Primicias 2025" class="w-full h-auto object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-smoke-900/90 via-smoke-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <span class="text-white font-medium font-sans text-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Bikurim 2025 (Fiesta de Primicias)</span>
                </div>
            </a>
            
            <!-- Item 2: Videos Retro OLD -->
            <a href="https://drive.google.com/drive/folders/1HpMS7ek1otbmbw_yRT-TJD1ELtPF2pk6?usp=sharing" target="_blank" rel="noopener noreferrer" class="masonry-item block gsap-gallery overflow-hidden rounded-xl relative group cursor-pointer">
                <img src="/para-web-3-1.webp" loading="lazy" decoding="async" alt="Videos Retro OLD" class="w-full h-auto object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-smoke-900/90 via-smoke-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <span class="text-white font-medium font-sans text-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Videos Retro OLD</span>
                </div>
            </a>
            
            <!-- Item 3: Recopilación de fotos 2025 -->
            <a href="https://drive.google.com/drive/folders/1g5F5Vh-BjSiiz9fUIt-QfbwlNqPWfPvd?usp=sharing" target="_blank" rel="noopener noreferrer" class="masonry-item block gsap-gallery overflow-hidden rounded-xl relative group cursor-pointer">
                <img src="/02.webp" loading="lazy" decoding="async" alt="Recopilación de fotos 2025" class="w-full h-auto object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-smoke-900/90 via-smoke-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <span class="text-white font-medium font-sans text-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Recopilación de fotos 2025</span>
                </div>
            </a>
            
            <!-- Item 4: Inspiración para las RRSS de tu Iglesia 2026 -->
            <a href="https://drive.google.com/drive/folders/1Hf91rR39nRHPzFd72GBEPZnPQA7MIEr3?usp=sharing" target="_blank" rel="noopener noreferrer" class="masonry-item block gsap-gallery overflow-hidden rounded-xl relative group cursor-pointer">
                <img src="/03.webp" loading="lazy" decoding="async" alt="Inspiración para las RRSS de tu Iglesia 2026" class="w-full h-auto object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-smoke-900/90 via-smoke-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <span class="text-white font-medium font-sans text-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Inspiración para las RRSS de tu Iglesia 2026</span>
                </div>
            </a>

            <!-- Item 5: Fotos Retro 1989 -->
            <a href="https://drive.google.com/drive/folders/1NoZq9KPq-uDsUMXJypirK5MgPm0SDtUR?usp=sharing" target="_blank" rel="noopener noreferrer" class="masonry-item block gsap-gallery overflow-hidden rounded-xl relative group cursor-pointer">
                <img src="/44.webp" loading="lazy" decoding="async" alt="Fotos Retro 1989" class="w-full h-auto object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-smoke-900/90 via-smoke-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <span class="text-white font-medium font-sans text-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Fotos Retro 1989</span>
                </div>
            </a>
        </div>
    </div>
</section>

<style>
    .masonry-grid { column-count: 1; column-gap: 1.5rem; }
    @media (min-width: 640px) { .masonry-grid { column-count: 2; } }
    @media (min-width: 1024px) { .masonry-grid { column-count: 3; } }
    .masonry-item { break-inside: avoid; margin-bottom: 1.5rem; }
</style>