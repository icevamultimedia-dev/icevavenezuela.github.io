---
---
<footer class="bg-smoke-900 border-t border-smoke-800 pt-20 pb-10 relative overflow-hidden font-sans">
    
    <!-- Destello de fondo sutil -->
    <div class="flare-bg w-[400px] h-[400px] bottom-[-200px] left-1/2 transform -translate-x-1/2 opacity-10 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <!-- 🌟 1. COLUMNAS DE ENLACES (Estilo Directorio) 🌟 -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-12 mb-16 text-left border-b border-smoke-800 pb-16">
            
            <!-- Columna 1: Nuestra Iglesia -->
            <div>
                <h4 class="text-white font-bold mb-5 text-sm md:text-base tracking-wide">Nuestra Iglesia</h4>
                <ul class="space-y-3">
                    <li><a href="/#inicio" class="text-gray-400 hover:text-white text-sm transition-colors">Inicio</a></li>
                    <li><a href="/nosotros" class="text-gray-400 hover:text-white text-sm transition-colors">Quiénes Somos</a></li>
                    <li><a href="/nosotros#mision" class="text-gray-400 hover:text-white text-sm transition-colors">Visión y Misión</a></li>
                </ul>
            </div>

            <!-- Columna 2: Horarios -->
            <div>
                <h4 class="text-white font-bold mb-5 text-sm md:text-base tracking-wide">Horarios</h4>
                <ul class="space-y-3">
                    <li><a href="/actividades/culto-dominical" data-astro-prefetch="hover" class="text-gray-400 hover:text-white text-sm transition-colors">Culto Dominical</a></li>
                    <li><a href="/#horarios" class="text-gray-400 hover:text-white text-sm transition-colors">Reunión de Jóvenes</a></li>
                    <li><a href="/#horarios" class="text-gray-400 hover:text-white text-sm transition-colors">Escuela Bíblica</a></li>
                </ul>
            </div>

            <!-- Columna 3: Actividades -->
            <div>
                <h4 class="text-white font-bold mb-5 text-sm md:text-base tracking-wide">Actividades</h4>
                <ul class="space-y-3">
                    <li><a href="/#galeria" class="text-gray-400 hover:text-white text-sm transition-colors">Ministerios</a></li>
                    <li><a href="/#galeria" class="text-gray-400 hover:text-white text-sm transition-colors">Galería de Fotos</a></li>
                    <li><a href="/#galeria" class="text-gray-400 hover:text-white text-sm transition-colors">Próximos Eventos</a></li>
                </ul>
            </div>

            <!-- Columna 4: Conecta -->
            <div>
                <h4 class="text-white font-bold mb-5 text-sm md:text-base tracking-wide">Conecta</h4>
                <ul class="space-y-3">
                    <li><a href="/#contacto" class="text-gray-400 hover:text-white text-sm transition-colors">Escríbenos</a></li>
                    <li><a href="/#contacto" class="text-gray-400 hover:text-white text-sm transition-colors">Peticiones de Oración</a></li>
                    <li class="pt-2">
                        <a href="https://maps.app.goo.gl/BhC3pvrDmrBsZvGY9" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white text-sm transition-colors block leading-relaxed">
                            <i class="fa-solid fa-location-dot mr-1 text-gold"></i> Morera, calle la gloria, al frente de la cancha del Mahomo.<br>
                            San Juan De Los Morros, VE
                        </a>
                    </li>
                </ul>
            </div>

        </div>

        <!-- 🌟 2. SECCIÓN CENTRAL (Logo, Lema y Botón) 🌟 -->
        <div class="flex flex-col lg:flex-row items-center justify-between py-8 mb-12 gap-8 text-center">
            
            <!-- Izquierda: Logo -->
            <div class="flex-shrink-0 lg:w-1/3 flex justify-center lg:justify-start">
                <img src="/para-web-2.svg" loading="lazy" decoding="async" alt="ICEVA Logo" class="h-16 md:h-20 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-500">
            </div>

            <!-- Centro: Lema principal -->
            <div class="lg:w-1/3 flex justify-center">
                <p class="text-gray-300 font-normal text-xs md:text-sm tracking-wide max-w-xs md:max-w-md leading-relaxed font-sans">
                    Una iglesia que se renueva todos los días en Cristo y que busca que tu tambien le conozcas.
                </p>
            </div>

            <!-- Derecha: Botón de Acción -->
            <div class="lg:w-1/3 flex justify-center lg:justify-end">
                <a href="/" data-astro-prefetch="hover" class="inline-block px-8 py-3.5 border border-white text-white rounded-full text-[10px] font-bold tracking-[0.15em] uppercase hover:bg-white hover:text-smoke-900 transition-colors duration-300 shadow-lg">
                    Encuentra una Iglesia en SJM
                </a>
            </div>

        </div>

        <!-- 🌟 3. REDES SOCIALES Y COPYRIGHT 🌟 -->
        <div class="flex flex-col items-center justify-center border-t border-smoke-800 pt-12">
            
            <!-- Redes Minimalistas (Icono + Texto) -->
            <div class="flex flex-wrap justify-center gap-6 md:gap-10 mb-10">
                <a href="https://www.facebook.com/icevavenezuela" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition-all text-sm font-semibold group">
                    <i class="fa-brands fa-facebook-f text-lg group-hover:scale-110 transition-transform"></i> <span class="hidden sm:inline">Facebook</span>
                </a>
                <a href="https://www.instagram.com/icevavenezuela/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition-all text-sm font-semibold group">
                    <i class="fa-brands fa-instagram text-lg group-hover:scale-110 transition-transform"></i> <span class="hidden sm:inline">Instagram</span>
                </a>
                <a href="https://www.youtube.com/@icevavenezuela" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition-all text-sm font-semibold group">
                    <i class="fa-brands fa-youtube text-lg group-hover:scale-110 transition-transform"></i> <span class="hidden sm:inline">YouTube</span>
                </a>
                <a href="https://www.tiktok.com/@icevavenezuela" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition-all text-sm font-semibold group">
                    <i class="fa-brands fa-tiktok text-lg group-hover:scale-110 transition-transform"></i> <span class="hidden sm:inline">TikTok</span>
                </a>
                <a href="https://vimeo.com/icevavenezuela" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition-all text-sm font-semibold group">
                    <i class="fa-brands fa-vimeo-v text-lg group-hover:scale-110 transition-transform"></i> <span class="hidden sm:inline">Vimeo</span>
                </a>
                <a href="https://linktr.ee/icevavenezuela" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition-all text-sm font-semibold group">
                    <i class="fa-solid fa-link text-lg group-hover:scale-110 transition-transform"></i> <span class="hidden sm:inline">Links</span>
                </a>
                <a href="https://drive.google.com/drive/folders/1BKUtUOWj8PYTuURNMmIxv-1NAtNr7xpJ?usp=sharing" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-400 hover:text-white transition-all text-sm font-semibold group">
                    <i class="fa-brands fa-google-drive text-lg group-hover:scale-110 transition-transform"></i> <span class="hidden sm:inline">Drive</span>
                </a>
            </div>

            <!-- Copyright -->
            <p class="text-[10px] text-gray-600 font-sans tracking-[0.2em] font-bold">
                &copy; 2026 Iglesia ICEVA. Santidad y Excelencia. Todos los derechos reservados.
            </p>

        </div>
    </div>
</footer>

