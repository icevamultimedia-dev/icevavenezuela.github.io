    <Footer />

    <script>
        import { gsap } from 'gsap';
        import { ScrollTrigger } from 'gsap/ScrollTrigger';
        gsap.registerPlugin(ScrollTrigger);

        window.onload = () => {
            const header = document.querySelector('header');
            const scrollTopBtn = document.getElementById('scroll-to-top');
            const perfBtn = document.getElementById('toggle-performance');
            const perfIcon = document.getElementById('perf-icon');
            const sideNav = document.getElementById('side-nav');
            const navDots = document.querySelectorAll('.nav-dot');

            // 🌟 ESTADO GLOBAL DE RENDIMIENTO 🌟
            let animationsEnabled = localStorage.getItem('iceva_performance') !== 'low';

            const updatePerfUI = () => {
                if (!animationsEnabled) {
                    perfIcon?.classList.replace('fa-bolt', 'fa-bolt-slash');
                    perfBtn?.classList.add('bg-gold', 'text-smoke-900');
                } else {
                    perfIcon?.classList.replace('fa-bolt-slash', 'fa-bolt');
                    perfBtn?.classList.remove('bg-gold', 'text-smoke-900');
                }
            };
            updatePerfUI();

            // 🌟 LÓGICA DEL MENÚ, SIDE NAV Y BOTÓN VOLVER ARRIBA 🌟
            if (header) {
                gsap.set(header, { yPercent: 0, autoAlpha: 1 });
                ScrollTrigger.create({
                    trigger: "#hero-mapas",
                    start: "top top",
                    end: "bottom top",
                    onLeave: () => {
                        gsap.to(header, { yPercent: -100, autoAlpha: 0, duration: 0.3 });
                        if (scrollTopBtn) gsap.to(scrollTopBtn, { autoAlpha: 1, visibility: 'visible', y: 0, duration: 0.5, ease: "back.out(1.7)" });
                        if (sideNav) gsap.to(sideNav, { autoAlpha: 1, visibility: 'visible', duration: 0.5 });
                    },
                    onEnterBack: () => {
                        gsap.to(header, { yPercent: 0, autoAlpha: 1, duration: 0.3 });
                        if (scrollTopBtn) gsap.to(scrollTopBtn, { autoAlpha: 0, visibility: 'hidden', y: 40, duration: 0.4 });
                        if (sideNav) gsap.to(sideNav, { autoAlpha: 0, visibility: 'hidden', duration: 0.5 });
                    }
                });
            }

            // 🌟 ACTUALIZAR PUNTO ACTIVO EN SIDE NAV 🌟
            const sections = gsap.utils.toArray('.section-target');
            sections.forEach((section, i) => {
                ScrollTrigger.create({
                    trigger: section as HTMLElement,
                    start: "top 60%",
                    end: "bottom 60%",
                    onToggle: self => {
                        if (self.isActive) {
                            navDots.forEach(dot => dot.querySelector('.dot-inner')?.classList.remove('bg-gold', 'scale-150', 'border-transparent'));
                            const activeDot = document.querySelector(`.nav-dot[data-section="${i+1}"]`);
                            activeDot?.querySelector('.dot-inner')?.classList.add('bg-gold', 'scale-150', 'border-transparent');
                        }
                    }
                });
            });

            // Special case for Hero dot
            ScrollTrigger.create({
                trigger: "#hero-mapas",
                start: "top top",
                end: "bottom bottom",
                onToggle: self => {
                    if (self.isActive) {
                        navDots.forEach(dot => dot.querySelector('.dot-inner')?.classList.remove('bg-gold', 'scale-150', 'border-transparent'));
                        document.querySelector('.nav-dot[data-section="0"]')?.querySelector('.dot-inner')?.classList.add('bg-gold', 'scale-150', 'border-transparent');
                    }
                }
            });

            // 🌟 LÓGICA DE REVELACIÓN CORREGIDA 🌟
            const reveals = gsap.utils.toArray('.gsap-reveal');
            reveals.forEach(elem => {
                gsap.from(elem as HTMLElement, {
                    scrollTrigger: { trigger: elem as HTMLElement, start: "top 95%", toggleActions: "play none none none" },
                    y: 30, autoAlpha: 0, duration: 1, clearProps: "all", ease: "power2.out"
                });
            });

            // 🌟 LÓGICA MAESTRA DE MAPAS 🌟
            const initMapSequence = (index: number) => {
                const section = document.getElementById(`mapa-${index}-section`);
                const video = document.getElementById(`mapa-${index}-video`) as HTMLVideoElement;
                const overlay = document.getElementById(`mapa-${index}-overlay`);
                const imageLayer = document.getElementById(`mapa-${index}-image-layer`);
                const markers = document.querySelectorAll(`.mapa-${index}-marker`);
                const distBadge = document.querySelector(`.mapa-${index}-distance`);
                if (!section || !video || !overlay || !imageLayer || markers.length === 0) return;

                if (!animationsEnabled) {
                    gsap.set([overlay, imageLayer], { autoAlpha: 1 });
                    gsap.set(markers, { opacity: 1, scale: 1, y: 0 });
                    gsap.set(distBadge, { opacity: 1, y: 0 });
                    gsap.set(video, { display: 'none' });
                    return;
                }

                gsap.set(video, { display: 'block' });
                gsap.set(markers, { opacity: 0, scale: 0, y: 20 });
                if (distBadge) gsap.set(distBadge, { opacity: 0, y: 30 });
                gsap.set([overlay, imageLayer], { autoAlpha: 0 });

                const setupTimeline = () => {
                    const videoDuration = video.duration;
                    if (!videoDuration || !isFinite(videoDuration)) return; 
                    video.pause();
                    const tl = gsap.timeline({ scrollTrigger: { trigger: section, start: "top top", end: "+=3000", pin: true, scrub: 1, anticipatePin: 1 } });
                    tl.fromTo(video, { currentTime: 0.01 }, { currentTime: videoDuration - 0.1, duration: 4, ease: "none" });
                    tl.to(overlay, { autoAlpha: 1, duration: 1 }, "+=0.2")
                      .to(imageLayer, { autoAlpha: 1, duration: 1 }, "<")
                      .set(imageLayer, { pointerEvents: "auto" }) 
                      .to(markers, { opacity: 1, scale: 1, y: 0, duration: 1.2, stagger: 0.2, ease: "back.out(1.4)" }, "-=0.5");
                    if (distBadge) tl.to(distBadge, { autoAlpha: 1, y: 0, duration: 1, ease: "power2.out" }, "<");
                    tl.to({}, { duration: 1.5 });
                };

                if (video.readyState >= 2) setupTimeline();
                else video.addEventListener('loadeddata', () => { setupTimeline(); ScrollTrigger.refresh(); });
            };

            setTimeout(() => {
                for(let i=1; i<=6; i++) initMapSequence(i);
                ScrollTrigger.refresh();
            }, 500);

            // Event Listeners
            if (perfBtn) perfBtn.addEventListener('click', () => { animationsEnabled = !animationsEnabled; localStorage.setItem('iceva_performance', animationsEnabled ? 'high' : 'low'); window.location.reload(); });
            if (scrollTopBtn) scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
            
            // Navegación suave para los dots
            navDots.forEach(dot => {
                dot.addEventListener('click', (e) => {
                    e.preventDefault();
                    const targetId = dot.getAttribute('href');
                    const targetElem = document.querySelector(targetId!);
                    if (targetElem) {
                        targetElem.scrollIntoView({ behavior: 'smooth' });
                    }
                });
            });
        };
    </script>
</Layout>