---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Encuentra una Iglesia | ICEVA">
    <Navbar />
    
    <main id="main-content" class="bg-smoke-900 overflow-x-hidden font-sans relative">

        <!-- 🌟 MENÚ LATERAL DE NAVEGACIÓN (DOTS CON DEGRADADO DE CONTRASTE) 🌟 -->
        <nav id="side-nav" class="fixed left-0 top-0 h-full w-40 z-[70] hidden lg:flex flex-col justify-center pl-10 gap-5 opacity-0 invisible transition-all duration-500 bg-gradient-to-r from-smoke-900/95 via-smoke-900/40 to-transparent pointer-events-none">
            <a href="#hero-mapas" class="nav-dot group relative flex items-center pointer-events-auto" data-section="0">
                <div class="w-2.5 h-2.5 rounded-full border border-gold/40 group-hover:bg-gold transition-all duration-300 dot-inner"></div>
                <span class="absolute left-6 bg-smoke-800 text-white text-[9px] px-2 py-1 rounded uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gold/20 font-sans">Inicio</span>
            </a>
            <div class="w-px h-4 bg-gold/20 ml-[4.5px]"></div>
            <a href="#mapa-1-trigger" class="nav-dot group relative flex items-center pointer-events-auto" data-section="1">
                <div class="w-2.5 h-2.5 rounded-full border border-gold/40 group-hover:bg-gold transition-all duration-300 dot-inner"></div>
                <span class="absolute left-6 bg-smoke-800 text-white text-[9px] px-2 py-1 rounded uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gold/20 font-sans">Centro</span>
            </a>
            <a href="#mapa-2-trigger" class="nav-dot group relative flex items-center pointer-events-auto" data-section="2">
                <div class="w-2.5 h-2.5 rounded-full border border-gold/40 group-hover:bg-gold transition-all duration-300 dot-inner"></div>
                <span class="absolute left-6 bg-smoke-800 text-white text-[9px] px-2 py-1 rounded uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gold/20 font-sans">Sur</span>
            </a>
            <a href="#mapa-3-trigger" class="nav-dot group relative flex items-center pointer-events-auto" data-section="3">
                <div class="w-2.5 h-2.5 rounded-full border border-gold/40 group-hover:bg-gold transition-all duration-300 dot-inner"></div>
                <span class="absolute left-6 bg-smoke-800 text-white text-[9px] px-2 py-1 rounded uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gold/20 font-sans">Este</span>
            </a>
            <a href="#mapa-4-trigger" class="nav-dot group relative flex items-center pointer-events-auto" data-section="4">
                <div class="w-2.5 h-2.5 rounded-full border border-gold/40 group-hover:bg-gold transition-all duration-300 dot-inner"></div>
                <span class="absolute left-6 bg-smoke-800 text-white text-[9px] px-2 py-1 rounded uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gold/20 font-sans">La Gloria</span>
            </a>
            <a href="#mapa-5-trigger" class="nav-dot group relative flex items-center pointer-events-auto" data-section="5">
                <div class="w-2.5 h-2.5 rounded-full border border-gold/40 group-hover:bg-gold transition-all duration-300 dot-inner"></div>
                <span class="absolute left-6 bg-smoke-800 text-white text-[9px] px-2 py-1 rounded uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gold/20 font-sans">Terminal</span>
            </a>
            <a href="#mapa-6-trigger" class="nav-dot group relative flex items-center pointer-events-auto" data-section="6">
                <div class="w-2.5 h-2.5 rounded-full border border-gold/40 group-hover:bg-gold transition-all duration-300 dot-inner"></div>
                <span class="absolute left-6 bg-smoke-800 text-white text-[9px] px-2 py-1 rounded uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gold/20 font-sans">Aeropuerto</span>
            </a>
            <div class="w-px h-4 bg-gold/20 ml-[4.5px]"></div>
            <a href="#final-message" class="nav-dot group relative flex items-center pointer-events-auto" data-section="7">
                <div class="w-2.5 h-2.5 rounded-full border border-gold/40 group-hover:bg-gold transition-all duration-300 dot-inner"></div>
                <span class="absolute left-6 bg-smoke-800 text-white text-[9px] px-2 py-1 rounded uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-gold/20 font-sans">Invitación</span>
            </a>
        </nav>
        
        <!-- 🌟 1. HERO ESTÁTICO (Rápido y Minimalista) 🌟 -->
        <section id="hero-mapas" class="relative h-[100svh] w-full flex items-center justify-center overflow-hidden border-b border-smoke-800">
            <div class="absolute inset-0 z-0 bg-smoke-900">
                <img src="/video-mapa-hero-poster.webp" alt="Mapas San Juan de los Morros" class="w-full h-full object-cover object-center opacity-30" onerror="this.src='/nosotros-hero.jpg'">
                <div class="absolute inset-0 bg-gradient-to-b from-smoke-900/90 via-smoke-900/40 to-smoke-900"></div>
            </div>
            <div class="flare-bg w-[800px] h-[800px] top-[-200px] left-1/2 transform -translate-x-1/2 opacity-20 z-0"></div>
            <div class="max-w-4xl mx-auto px-4 relative z-20 text-center">
                <span class="gsap-hero block text-blue-400 tracking-[0.3em] text-[10px] md:text-xs uppercase mb-4 font-semibold">ICEVA en San Juan De Los Morros</span>
                <h1 class="gsap-hero text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight drop-shadow-2xl">
                    Como llegar a nuestra <span class="font-serif text-transparent bg-clip-text bg-gradient-to-r from-blue-200 to-blue-500 normal-case pr-4 inline-block">Sede</span>
                </h1>
                <p class="gsap-hero text-gray-400 text-sm md:text-base font-light leading-relaxed max-w-xl mx-auto">
                    Explora nuestro mapa y descubre como llegar a nuestra sede principal. Hay una familia espiritual esperando por ti muy cerca de tu hogar.
                </p>
                <div class="gsap-hero mt-10">
                    <div class="animate-bounce inline-flex items-center justify-center w-10 h-10 rounded-full border border-smoke-700 text-gold">
                        <i class="fa-solid fa-arrow-down"></i>
                    </div>
                </div>
            </div>
        </section>

        <!-- 🌟 CONTENEDOR DE LOS MAPAS 🌟 -->
        <div id="mapas-trigger">
            
            <!-- SECTOR 1 -->
            <section id="mapa-1-trigger" class="py-20 md:py-32 bg-smoke-900 border-b border-smoke-800 flex items-center justify-center relative z-40 section-target">
                <h2 class="gsap-reveal text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-wide text-center uppercase">
                    Los Samanes - <span class="text-blue-400">ICEVA</span>
                </h2>
            </section>

            <!-- OPTIMIZADO: flex-col para apilar el mapa arriba y el banner abajo en móviles -->
            <section id="mapa-1-section" class="relative h-[100svh] w-full flex flex-col items-center justify-center overflow-hidden border-b border-smoke-800 bg-smoke-900 map-section">
                
                <div id="mapa-1-image-layer" class="relative w-full aspect-[4/3] md:aspect-video lg:absolute lg:inset-0 lg:aspect-auto lg:w-full lg:h-full z-30 image-layer overflow-hidden border-y border-smoke-700 lg:border-none shadow-2xl lg:shadow-none">
                    <img src="/mapa-1-static.webp" loading="lazy" decoding="async" alt="Mapa Sector Centro" class="absolute inset-0 w-full h-full object-cover transform scale-[1.15] image-zoom origin-center will-change-transform" onerror="this.style.display='none'" />
                    
                    <!-- Marcadores -->
                    <div class="mapa-1-marker absolute top-[10%] left-[15%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-yellow-400 rounded-full flex items-center justify-center text-smoke-900 shadow-[0_0_10px_rgba(250,204,21,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-tree text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">La plaza de los samanes</div>
                    </div>
                    <div class="mapa-1-marker absolute top-[20%] left-[22%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-green-500 rounded-full flex items-center justify-center text-white shadow-[0_0_10px_rgba(34,197,94,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-pizza-slice text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Restaurante TropiPizza</div>
                    </div>
                    <div class="mapa-1-marker absolute top-[30%] left-[34%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-red-500 rounded-full flex items-center justify-center text-white shadow-[0_0_10px_rgba(239,68,68,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-hospital text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Hospital Israel Ranuárez Balza</div>
                    </div>
                    <div class="mapa-1-marker absolute top-[38%] left-[39%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-white rounded-full flex items-center justify-center text-smoke-900 shadow-[0_0_10px_rgba(255,255,255,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-traffic-light text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Semáforo del hospital</div>
                    </div>
                    <div class="mapa-1-marker absolute top-[86%] left-[78%] flex flex-col items-center pointer-events-auto cursor-pointer group z-50 marker-pin active:scale-95">
                        <div class="w-8 h-8 md:w-10 md:h-10 bg-blue-500 rounded-full flex items-center justify-center text-white shadow-[0_0_15px_rgba(59,130,246,0.8)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-church text-[12px] md:text-sm"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[9px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-bold font-sans text-center leading-tight">Iglesia ICEVA</div>
                    </div>
                </div>

                <!-- Banner de Distancia (Fuera de la imagen en móviles) -->
                <div class="mapa-1-distance relative mt-4 lg:mt-0 lg:absolute lg:bottom-10 lg:left-10 lg:translate-x-0 w-[90%] sm:w-auto z-50 bg-smoke-800/95 backdrop-blur-md border border-gold/30 px-4 md:px-6 py-3 md:py-4 rounded-xl md:rounded-2xl shadow-2xl flex items-center gap-4 opacity-0 translate-y-10 distance-badge">
                    <div class="w-8 h-8 md:w-12 md:h-12 shrink-0 rounded-full bg-gold/10 flex items-center justify-center text-gold"><i class="fa-solid fa-route text-sm md:text-lg"></i></div>
                    <div class="flex flex-col text-left">
                        <span class="text-[8px] md:text-[10px] uppercase tracking-widest text-gray-400 font-bold font-sans leading-tight">Distancia Estimada</span>
                        <span class="text-white font-bold text-[11px] sm:text-sm md:text-base tracking-tight leading-tight">1.66 km | Los Samanes → ICEVA</span>
                    </div>
                </div>
            </section>

            <!-- SECTOR 2 -->
            <section id="mapa-2-trigger" class="py-20 md:py-32 bg-smoke-900 border-b border-smoke-800 flex items-center justify-center relative z-40 section-target">
                <h2 class="gsap-reveal text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-wide text-center uppercase">
                    Plaza Bolivar - <span class="text-blue-400">ICEVA</span>
                </h2>
            </section>

            <section id="mapa-2-section" class="relative h-[100svh] w-full flex flex-col items-center justify-center overflow-hidden border-b border-smoke-800 bg-smoke-900 map-section">
                
                <div id="mapa-2-image-layer" class="relative w-full aspect-[4/3] md:aspect-video lg:absolute lg:inset-0 lg:aspect-auto lg:w-full lg:h-full z-30 image-layer overflow-hidden border-y border-smoke-700 lg:border-none shadow-2xl lg:shadow-none">
                    <img src="/mapa-2-static.webp" loading="lazy" decoding="async" alt="Mapa Sector Sur" class="absolute inset-0 w-full h-full object-cover transform scale-[1.15] image-zoom origin-center will-change-transform" onerror="this.style.display='none'" />
                    
                    <div class="mapa-2-marker absolute top-[12%] left-[25%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-green-500 rounded-full flex items-center justify-center text-white shadow-[0_0_10px_rgba(34,197,94,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-monument text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Plaza Bolívar</div>
                    </div>
                    <div class="mapa-2-marker absolute top-[20%] left-[48%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-yellow-400 rounded-full flex items-center justify-center text-smoke-900 shadow-[0_0_10px_rgba(250,204,21,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-road text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Carretera Nacional Troncal 2</div>
                    </div>
                    <div class="mapa-2-marker absolute top-[35%] left-[18%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-red-500 rounded-full flex items-center justify-center text-white shadow-[0_0_10px_rgba(239,68,68,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-hospital text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Hospital Israel Ranuárez Balza</div>
                    </div>
                    <div class="mapa-2-marker absolute top-[42%] left-[23%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-white rounded-full flex items-center justify-center text-smoke-900 shadow-[0_0_10px_rgba(255,255,255,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-traffic-light text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Semáforo del hospital</div>
                    </div>
                    <div class="mapa-2-marker absolute top-[78%] left-[74%] flex flex-col items-center pointer-events-auto cursor-pointer group z-50 marker-pin active:scale-95">
                        <div class="w-8 h-8 md:w-10 md:h-10 bg-blue-500 rounded-full flex items-center justify-center text-white shadow-[0_0_15px_rgba(59,130,246,0.8)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-church text-[12px] md:text-sm"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[9px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-bold font-sans text-center leading-tight">Iglesia ICEVA</div>
                    </div>
                </div>

                <div class="mapa-2-distance relative mt-4 lg:mt-0 lg:absolute lg:bottom-10 lg:left-10 lg:translate-x-0 w-[90%] sm:w-auto z-50 bg-smoke-800/95 backdrop-blur-md border border-gold/30 px-4 md:px-6 py-3 md:py-4 rounded-xl md:rounded-2xl shadow-2xl flex items-center gap-4 opacity-0 translate-y-10 distance-badge">
                    <div class="w-8 h-8 md:w-12 md:h-12 shrink-0 rounded-full bg-gold/10 flex items-center justify-center text-gold"><i class="fa-solid fa-route text-sm md:text-lg"></i></div>
                    <div class="flex flex-col text-left"><span class="text-[8px] md:text-[10px] uppercase tracking-widest text-gray-400 font-bold font-sans leading-tight">Distancia Estimada</span><span class="text-white font-bold text-[11px] sm:text-sm md:text-base tracking-tight leading-tight">1.68 km | Plaza Bolívar → ICEVA</span></div>
                </div>
            </section>

            <!-- SECTOR 3 -->
            <section id="mapa-3-trigger" class="py-20 md:py-32 bg-smoke-900 border-b border-smoke-800 flex items-center justify-center relative z-40 section-target">
                <h2 class="gsap-reveal text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-wide text-center uppercase">
                    Banco Obrero - <span class="text-blue-400">ICEVA</span>
                </h2>
            </section>

            <section id="mapa-3-section" class="relative h-[100svh] w-full flex flex-col items-center justify-center overflow-hidden border-b border-smoke-800 bg-smoke-900 map-section">
                
                <div id="mapa-3-image-layer" class="relative w-full aspect-[4/3] md:aspect-video lg:absolute lg:inset-0 lg:aspect-auto lg:w-full lg:h-full z-30 image-layer overflow-hidden border-y border-smoke-700 lg:border-none shadow-2xl lg:shadow-none">
                    <img src="/mapa-3-static.webp" loading="lazy" decoding="async" alt="Mapa Sector Este" class="absolute inset-0 w-full h-full object-cover transform scale-[1.15] image-zoom origin-center will-change-transform" onerror="this.style.display='none'" />
                    
                    <div class="mapa-3-marker absolute top-[8%] left-[48%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-yellow-400 rounded-full flex items-center justify-center text-smoke-900 shadow-[0_0_10px_rgba(250,204,21,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-building text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Sector Banco Obrero</div>
                    </div>
                    <div class="mapa-3-marker absolute top-[22%] left-[78%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-green-500 rounded-full flex items-center justify-center text-white shadow-[0_0_10px_rgba(34,197,94,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-landmark text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">La Villa Olímpica</div>
                    </div>
                    <div class="mapa-3-marker absolute top-[46%] left-[50%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-red-500 rounded-full flex items-center justify-center text-white shadow-[0_0_10px_rgba(239,68,68,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-hospital text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Hospital Israel Ranuárez Balza</div>
                    </div>
                    <div class="mapa-3-marker absolute top-[53%] left-[49%] flex flex-col items-center pointer-events-auto cursor-pointer group z-40 marker-pin active:scale-95">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-white rounded-full flex items-center justify-center text-smoke-900 shadow-[0_0_10px_rgba(255,255,255,0.6)] group-hover:scale-110 transition-transform relative z-10"><i class="fa-solid fa-traffic-light text-[10px] md:text-xs"></i></div>
                        <div class="absolute top-full mt-1.5 left-1/2 -translate-x-1/2 bg-smoke-800/95 backdrop-blur-sm border border-smoke-700 px-2 py-1 rounded md:rounded-lg text-[8px] md:text-[10px] text-white whitespace-nowrap pointer-events-none z-20 shadow-lg font-medium font-sans text-center leading-tight">Semáforo del hospital</div>
