    <script>
        import { gsap } from 'gsap';
        import { ScrollTrigger } from 'gsap/ScrollTrigger';
        gsap.registerPlugin(ScrollTrigger);

        document.addEventListener("DOMContentLoaded", () => {
            const header = document.querySelector('header');
            const sideNav = document.getElementById('side-nav');
            const navDots = document.querySelectorAll('.nav-dot');
            const scrollTopBtn = document.getElementById('scroll-to-top');
            const perfBtn = document.getElementById('toggle-performance');
            const perfIcon = document.getElementById('perf-icon');

            let animationsEnabled = localStorage.getItem('iceva_performance') !== 'low';

            const updatePerfUI = () => {
                if (!animationsEnabled) {
                    perfIcon?.classList.replace('fa-bolt', 'fa-bolt-slash');
                    perfBtn?.classList.add('bg-gold', 'text-smoke-900');
                } else {
                    perfIcon?.classList.replace('fa-bolt-slash', 'fa-bolt');
                    perfBtn?.classList.remove('bg-gold', 'text-smoke-900');
                }
            };
            updatePerfUI();

            if (header) {
                gsap.set(header, { yPercent: 0, autoAlpha: 1 });
                ScrollTrigger.create({
                    trigger: "#hero-mapas", start: "top top", end: "bottom top",
                    onLeave: () => {
                        gsap.to(header, { yPercent: -100, autoAlpha: 0, duration: 0.3 });
                        if (sideNav) gsap.to(sideNav, { autoAlpha: 1, visibility: 'visible', duration: 0.5 });
                        if (scrollTopBtn) gsap.to(scrollTopBtn, { autoAlpha: 1, visibility: 'visible', y: 0, duration: 0.5, ease: "back.out(1.7)" });
                    },
                    onEnterBack: () => {
                        gsap.to(header, { yPercent: 0, autoAlpha: 1, duration: 0.3 });
                        if (sideNav) gsap.to(sideNav, { autoAlpha: 0, visibility: 'hidden', duration: 0.5 });
                        if (scrollTopBtn) gsap.to(scrollTopBtn, { autoAlpha: 0, visibility: 'hidden', y: 40, duration: 0.4 });
                    }
                });
            }

            const sections = gsap.utils.toArray('.section-target');
            sections.forEach((section, i) => {
                ScrollTrigger.create({
                    trigger: section as HTMLElement, start: "top 60%", end: "bottom 60%",
                    onToggle: self => {
                        if (self.isActive) {
                            navDots.forEach(dot => dot.querySelector('.dot-inner')?.classList.remove('bg-gold', 'scale-150', 'border-transparent'));
                            const activeDot = document.querySelector(`.nav-dot[data-section="${i+1}"]`);
                            activeDot?.querySelector('.dot-inner')?.classList.add('bg-gold', 'scale-150', 'border-transparent');
                        }
                    }
                });
            });

            // Special case for Hero dot
            ScrollTrigger.create({
                trigger: "#hero-mapas",
                start: "top top",
                end: "bottom bottom",
                onToggle: self => {
                    if (self.isActive) {
                        navDots.forEach(dot => dot.querySelector('.dot-inner')?.classList.remove('bg-gold', 'scale-150', 'border-transparent'));
                        document.querySelector('.nav-dot[data-section="0"]')?.querySelector('.dot-inner')?.classList.add('bg-gold', 'scale-150', 'border-transparent');
                    }
                }
            });

            // 🌟 LÓGICA MINIMALISTA DE MAPAS (IMAGENES Y ANIMACIONES) 🌟
            const initMapSequence = (index: number) => {
                const section = document.getElementById(`mapa-${index}-section`);
                const imageZoom = section?.querySelector('.image-zoom');
                const markers = document.querySelectorAll(`.mapa-${index}-marker`);
                const distBadge = document.querySelector(`.mapa-${index}-distance`);
                
                if (!section || !imageZoom) return;

                if (!animationsEnabled) {
                    gsap.set(imageZoom, { scale: 1 });
                    if (markers.length) gsap.set(markers, { opacity: 1, scale: 1, y: 0 });
                    if (distBadge) gsap.set(distBadge, { opacity: 1, y: 0 });
                    return;
                }
                
                // Preparar elementos ocultos
                if (markers.length) gsap.set(markers, { opacity: 0, scale: 0, y: 20 });
                if (distBadge) gsap.set(distBadge, { opacity: 0, y: 30 });

                // Crear el Pin
                const tl = gsap.timeline({ 
                    scrollTrigger: { 
                        trigger: section, 
                        start: "top top", 
                        end: "+=1200", 
                        pin: true, 
                        scrub: 1, 
                        anticipatePin: 1 
                    } 
                });

                // 1. Zoom Out Suave de la imagen
                tl.to(imageZoom, { scale: 1, duration: 2, ease: "power1.out" });

                // 2. Aparecen los marcadores saltando
                if (markers.length) tl.to(markers, { opacity: 1, scale: 1, y: 0, duration: 1.2, stagger: 0.15, ease: "back.out(1.4)" }, "-=1.5");
                
                // 3. Aparece el banner de distancia
                if (distBadge) tl.to(distBadge, { autoAlpha: 1, y: 0, duration: 1, ease: "power2.out" }, "-=1");
                
                tl.to({}, { duration: 0.5 }); // Pausa final para estabilizar
            };

            setTimeout(() => { 
                for(let i=1; i<=6; i++) initMapSequence(i); 
                ScrollTrigger.refresh(); 
            }, 100);

            navDots.forEach(dot => {
                dot.addEventListener('click', (e) => {
                    e.preventDefault();
                    const targetId = dot.getAttribute('href');
                    const targetElem = document.querySelector(targetId!);
                    if (targetElem) targetElem.scrollIntoView({ behavior: 'smooth' });
                });
            });

            // Animaciones Reveal (Títulos)
            const reveals = gsap.utils.toArray('.gsap-reveal');
            reveals.forEach(elem => {
                if (animationsEnabled) {
                    gsap.fromTo(elem as HTMLElement, 
                        { autoAlpha: 0, y: 40 },
                        {
                            scrollTrigger: { trigger: elem as HTMLElement, start: "top 85%", toggleActions: "play none none none" },
                            autoAlpha: 1, y: 0, duration: 1, clearProps: "all", ease: "power3.out"
                        }
                    );
                } else gsap.set(elem as HTMLElement, { autoAlpha: 1, y: 0, clearProps: "all" });
            });

            // Event Listeners UI
            if (perfBtn) perfBtn.addEventListener('click', () => { animationsEnabled = !animationsEnabled; localStorage.setItem('iceva_performance', animationsEnabled ? 'high' : 'low'); window.location.reload(); });
            if (scrollTopBtn) scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        });
    </script>
</Layout>